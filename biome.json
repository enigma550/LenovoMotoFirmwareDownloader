{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["runtime/**", "core/**", "web/**", "tooling/**", "types/electrobun/**"]
  },
  "formatter": {
    "enabled": true,
    "includes": [
      "runtime/**/*.ts",
      "core/**/*.ts",
      "web/**/*.ts",
      "web/**/*.css",
      "tooling/**/*.ts"
    ],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "includes": [
      "runtime/**/*.ts",
      "core/**/*.ts",
      "web/**/*.ts",
      "web/**/*.css",
      "tooling/**/*.ts"
    ],
    "rules": {
      "recommended": true,
      "complexity": {
        "useLiteralKeys": "off"
      },
      "suspicious": {
        "noExplicitAny": "error"
      },
      "correctness": {
        "noUnknownTypeSelector": "error"
      },
      "style": {
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "includes": [
      "runtime/**/*.ts",
      "core/**/*.ts",
      "web/**/*.ts",
      "web/**/*.css",
      "tooling/**/*.ts"
    ],
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "html": {
    "parser": {
      "interpolation": true
    }
  }
}
